{
  "name": "wechat-codex",
  "version": "0.1.0",
  "description": "Direct personal WeChat bridge to the local logged-in Codex CLI.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postinstall": "npm run build",
    "dev": "tsc --watch -p tsconfig.json",
    "test": "node --test dist/tests/bridge-command.test.js dist/tests/gateway-runtime.test.js dist/tests/session.test.js dist/tests/sender.test.js dist/tests/tokens.test.js",
    "setup": "node dist/main.js setup",
    "start": "node dist/main.js start",
    "service": "node dist/main.js service",
    "logs": "node dist/main.js service logs"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "wechat",
    "codex",
    "wechat-bot",
    "local-codex",
    "bridge",
    "chatgpt"
  ],
  "license": "MIT"
}
